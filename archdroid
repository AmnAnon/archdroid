#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║  ArchDroid — archdroid (Main CLI Interface)                     ║
# ║  Unified Command-Line Interface for ArchDroid System            ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── STRICT MODE ─────────────────────────────────────────────────────────────
set -euo pipefail

# ─── CONFIGURATION ───────────────────────────────────────────────────────────
# Robust script location resolution that handles symlinks properly
if command -v realpath >/dev/null 2>&1; then
    # Use realpath if available (most modern systems)
    SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
else
    # Fallback for systems without realpath
    SCRIPT_PATH="${BASH_SOURCE[0]}"
    # Follow symlinks manually
    while [ -L "$SCRIPT_PATH" ]; do
        local link_target
        link_target="$(readlink "$SCRIPT_PATH")"
        if [[ "$link_target" == /* ]]; then
            SCRIPT_PATH="$link_target"
        else
            SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$link_target"
        fi
    done
fi

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
CORE_DIR="$SCRIPT_DIR/core"

# Default paths
export ARCH_PATH="${ARCH_PATH:-/data/local/arch}"

# Load version info for display
source "${CORE_DIR}/versions.sh"

# ─── COLORS ──────────────────────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

ok()   { echo -e "${GREEN}  ✔  $*${RESET}"; }
warn() { echo -e "${YELLOW}  ⚠  $*${RESET}"; }
fail() { echo -e "${RED}  ✘  $*${RESET}"; }
info() { echo -e "${CYAN}  ▶  $*${RESET}"; }

banner() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════╗"
    printf "  ║  %-48s║\n" "$*"
    echo "  ╚══════════════════════════════════════════════════╝"
    echo -e "${RESET}"
}

# ─── COMMAND FUNCTIONS ───────────────────────────────────────────────────────

cmd_version() {
    banner "ArchDroid v$ARCH_VERSION"
    echo "Secure, deterministic Arch Linux runtime for Android"
    echo ""
    echo "Configuration:"
    echo "  Install Path: $ARCH_PATH"
    echo "  Core Scripts: $CORE_DIR"
    echo "  Target Version: $ARCH_VERSION"

    local current_version
    current_version=$(get_current_version "/data/local/archdroid-state" 2>/dev/null || echo "none")
    echo "  Installed Version: $current_version"

    echo ""
    echo "Trust Model:"
    echo "  External verification required for production use"
    echo "  See TRUST_MODEL.md for security boundaries"
}

cmd_bootstrap() {
    banner "ArchDroid Bootstrap"
    info "Starting secure bootstrap process..."
    exec "${CORE_DIR}/bootstrap.sh" "$@"
}

cmd_start() {
    banner "ArchDroid Runtime"
    info "Starting deterministic runtime system..."
    exec "${CORE_DIR}/runtime.sh" "$@"
}

cmd_update() {
    banner "ArchDroid Update"
    info "Starting atomic update process..."
    exec "${CORE_DIR}/atomic-update.sh" "$@"
}

cmd_doctor() {
    banner "ArchDroid System Diagnostics"
    info "Running comprehensive system inspection..."
    exec "${CORE_DIR}/inspect-runtime.sh" "$@"
}

cmd_verify() {
    banner "ArchDroid Verification"
    info "Running independent system verification..."
    exec "${CORE_DIR}/verify.sh" "$@"
}

cmd_reset_trust() {
    banner "ArchDroid Trust Reset"
    info "Clearing all accumulated trust state..."
    exec "${CORE_DIR}/trust-reset.sh" "$@"
}

cmd_status() {
    banner "ArchDroid System Status"

    # Installation status — check both presence and chroot validity
    if [ -f "$ARCH_PATH/bin/bash" ]; then
        local current_version
        current_version=$(get_current_version "/data/local/archdroid-state" 2>/dev/null || echo "none")

        # Quick chroot smoke-test to distinguish "files present" from "actually works"
        if chroot "$ARCH_PATH" /bin/bash -c 'echo ok' >/dev/null 2>&1; then
            ok "Installation: Valid and executable (version: $current_version)"
        else
            warn "Installation: Files present but chroot test failed (version: $current_version)"
            info "Run 'archdroid doctor' — SELinux is a common cause"
        fi
    else
        warn "Installation: Not found"
        info "Run 'archdroid bootstrap' to install"
        return 1
    fi

    # Runtime status check
    info "Checking runtime system status..."
    local inspect_status=0
    "${CORE_DIR}/inspect-runtime.sh" >/dev/null 2>&1 || inspect_status=$?
    if [ "$inspect_status" -eq 0 ] || [ "$inspect_status" -eq 1 ]; then
        ok "Runtime: Ready"
    else
        warn "Runtime: Issues detected"
        info "Run 'archdroid doctor' for detailed diagnosis"
    fi

    # Trust state
    local trust_marker="${ARCH_PATH}/.archdroid-trust-reset"
    if [ -f "$trust_marker" ]; then
        warn "Trust: Reset required (marked as untrusted)"
        info "Run 'archdroid reset-trust' then 'archdroid bootstrap'"
    else
        ok "Trust: Clean state"
    fi

    echo ""
    info "System ready for 'archdroid start'"
}

cmd_help() {
    banner "ArchDroid Commands"
    echo ""
    echo "Setup Commands:"
    echo "  bootstrap     Install Arch Linux rootfs with security verification"
    echo "  update        Atomically update existing installation"
    echo "  reset-trust   Clear all accumulated state and force fresh bootstrap"
    echo ""
    echo "Runtime Commands:"
    echo "  start         Enter secure chroot environment"
    echo "  status        Show system and installation status"
    echo ""
    echo "Diagnostic Commands:"
    echo "  doctor        Run comprehensive system diagnostics"
    echo "  verify        Independent verification of installation"
    echo "  version       Show version and configuration information"
    echo ""
    echo "Environment Variables:"
    echo "  ARCH_PATH           Installation directory (default: /data/local/arch)"
    echo "  ARCHDROID_SAFE_MODE Enable safe mode to bypass hard gates (debugging)"
    echo ""
    echo "Security Notes:"
    echo "  - External checksum verification required for production"
    echo "  - See TRUST_MODEL.md for security boundaries"
    echo "  - Requires root access for proper mount handling"
    echo ""
    echo "Examples:"
    echo "  archdroid bootstrap    # Initial installation"
    echo "  archdroid start        # Enter chroot"
    echo "  archdroid doctor       # Diagnose issues"
    echo "  archdroid update       # Update to latest version"
}

# ─── MAIN COMMAND DISPATCHER ─────────────────────────────────────────────────
main() {
    # Validate core directory exists
    if [ ! -d "$CORE_DIR" ]; then
        fail "Core directory not found: $CORE_DIR"
        exit 1
    fi

    # Parse command
    local command="${1:-help}"
    shift || true

    case "$command" in
        "bootstrap"|"install")
            cmd_bootstrap "$@"
            ;;
        "start"|"run"|"enter")
            cmd_start "$@"
            ;;
        "update"|"upgrade")
            cmd_update "$@"
            ;;
        "doctor"|"diagnose"|"check")
            cmd_doctor "$@"
            ;;
        "verify"|"validate")
            cmd_verify "$@"
            ;;
        "reset-trust"|"reset")
            cmd_reset_trust "$@"
            ;;
        "status"|"info")
            cmd_status "$@"
            ;;
        "version"|"--version"|"-v")
            cmd_version "$@"
            ;;
        "help"|"--help"|"-h")
            cmd_help "$@"
            ;;
        *)
            fail "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

# ─── MAIN EXECUTION ──────────────────────────────────────────────────────────
if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi