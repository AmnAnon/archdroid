#!/bin/bash
# ╔══════════════════════════════════════════════════════════════════╗
# ║  ArchDroid — archdroid (Main CLI Interface)                     ║
# ║  Unified Command-Line Interface for ArchDroid System            ║
# ╚══════════════════════════════════════════════════════════════════╝

set -euo pipefail

# ─── SCRIPT LOCATION (symlink-safe) ──────────────────────────────────────────
if command -v realpath >/dev/null 2>&1; then
    SCRIPT_PATH="$(realpath "${BASH_SOURCE[0]}")"
else
    SCRIPT_PATH="${BASH_SOURCE[0]}"
    while [ -L "$SCRIPT_PATH" ]; do
        link_target="$(readlink "$SCRIPT_PATH")"
        if [[ "$link_target" == /* ]]; then
            SCRIPT_PATH="$link_target"
        else
            SCRIPT_PATH="$(dirname "$SCRIPT_PATH")/$link_target"
        fi
    done
fi

SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_PATH")" && pwd)"
CORE_DIR="$SCRIPT_DIR/core"

export ARCH_PATH="${ARCH_PATH:-/data/local/arch}"

source "${CORE_DIR}/versions.sh"

# ─── OUTPUT HELPERS ──────────────────────────────────────────────────────────
GREEN='\033[0;32m'; YELLOW='\033[1;33m'; RED='\033[0;31m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

ok()     { echo -e "${GREEN}  ✔  $*${RESET}"; }
warn()   { echo -e "${YELLOW}  ⚠  $*${RESET}"; }
fail()   { echo -e "${RED}  ✘  $*${RESET}"; }
info()   { echo -e "${CYAN}  ▶  $*${RESET}"; }

banner() {
    echo -e "${BOLD}${CYAN}"
    echo "  ╔══════════════════════════════════════════════════╗"
    printf "  ║  %-48s║\n" "$*"
    echo "  ╚══════════════════════════════════════════════════╝"
    echo -e "${RESET}"
}

# ─── COMMANDS ────────────────────────────────────────────────────────────────

cmd_version() {
    banner "ArchDroid v$ARCH_VERSION"
    echo "Secure, deterministic Arch Linux runtime for Android"
    echo ""
    echo "Configuration:"
    echo "  Install Path: $ARCH_PATH"
    echo "  Core Scripts: $CORE_DIR"
    echo "  Target Version: $ARCH_VERSION"
    local current_version
    current_version=$(get_current_version "$ARCH_PATH" 2>/dev/null || echo "none")
    echo "  Installed Version: $current_version"
    echo ""
    echo "Trust Model:"
    echo "  External verification required for production use"
    echo "  See TRUST_MODEL.md for security boundaries"
}

cmd_up() {
    banner "ArchDroid Full Setup + Update"

    export ARCHDROID_AUTO_SELINUX="${ARCHDROID_AUTO_SELINUX:-1}"

    # ── Step 1: Bootstrap if rootfs is missing ──────────────────────────────
    if [ ! -f "$ARCH_PATH/bin/bash" ]; then
        info "No rootfs found — running bootstrap first..."
        echo ""
        ARCHDROID_BOOTSTRAP_ALLOWED=1 ARCHDROID_INTERNAL_CALL=1 "${CORE_DIR}/bootstrap.sh" || {
            fail "Bootstrap failed — run 'archdroid doctor' for details"
            exit 1
        }
        echo ""
    else
        local current_version
        current_version=$(get_current_version "$ARCH_PATH" 2>/dev/null || echo "none")

        if [ "$current_version" = "none" ] && [ "${ARCHDROID_FORCE:-0}" != "1" ]; then
            echo ""
            fail "Existing Arch installation detected at: $ARCH_PATH"
            fail "This system was not installed by ArchDroid — refusing to modify."
            echo ""
            echo "  Run this to test safely (separate path, no risk):"
            echo ""
            echo -e "    ${BOLD}export ARCH_PATH=/data/local/arch-test && archdroid up${RESET}"
            echo ""
            echo "  Or to force overwrite (destructive):"
            echo ""
            echo -e "    ${BOLD}ARCHDROID_FORCE=1 archdroid up${RESET}"
            echo ""
            exit 1
        elif [ "$current_version" = "none" ] && [ "${ARCHDROID_FORCE:-0}" = "1" ]; then
            echo ""
            warn "ARCHDROID_FORCE=1 — preparing to overwrite unmanaged rootfs at $ARCH_PATH"
            echo ""
            if [ -t 0 ]; then
                printf "  ⚠  This will overwrite the existing system. Continue? [y/N]: "
                read -r confirm </dev/tty
                if [ "$confirm" != "y" ] && [ "$confirm" != "Y" ]; then
                    info "Aborted."
                    exit 1
                fi
            else
                fail "ARCHDROID_FORCE=1 requires interactive confirmation"
                exit 1
            fi
        fi
        ok "Rootfs: $ARCH_PATH (version: $current_version)"
    fi

    # ── Step 2: SELinux ──────────────────────────────────────────────────────
    if command -v getenforce >/dev/null 2>&1; then
        local selinux_mode
        selinux_mode=$(getenforce 2>/dev/null || echo "unknown")
        if [ "$selinux_mode" = "Enforcing" ]; then
            warn "SELinux Enforcing → setting Permissive (temporary, resets on reboot)"
            if setenforce 0 2>/dev/null; then
                ok "SELinux → Permissive"
            else
                fail "setenforce 0 failed — are you root?"
                exit 1
            fi
        else
            ok "SELinux: $selinux_mode"
        fi
    fi

    # ── Step 3: Mounts ───────────────────────────────────────────────────────
    info "Setting up mount points..."
    local d
    for d in proc sys dev dev/pts tmp; do mkdir -p "$ARCH_PATH/$d"; done

    mountpoint -q "$ARCH_PATH/proc"    || mount -t proc  proc     "$ARCH_PATH/proc"    2>/dev/null && ok "proc"    || warn "proc mount failed"
    mountpoint -q "$ARCH_PATH/sys"     || mount -t sysfs sysfs    "$ARCH_PATH/sys"     2>/dev/null && ok "sys"     || warn "sys mount failed"
    mountpoint -q "$ARCH_PATH/dev"     || mount --rbind  /dev     "$ARCH_PATH/dev"     2>/dev/null && ok "dev"     || warn "dev mount failed"
    mountpoint -q "$ARCH_PATH/dev/pts" || mount --rbind  /dev/pts "$ARCH_PATH/dev/pts" 2>/dev/null && ok "dev/pts" || warn "dev/pts mount failed"
    mountpoint -q "$ARCH_PATH/tmp"     || mount -t tmpfs -o size=512m,mode=1777 tmpfs "$ARCH_PATH/tmp" 2>/dev/null && ok "tmp" || warn "tmp mount failed"

    # ── Step 4: DNS ──────────────────────────────────────────────────────────
    local resolv="$ARCH_PATH/etc/resolv.conf"
    if [ ! -s "$resolv" ]; then
        printf 'nameserver 1.1.1.1\nnameserver 8.8.8.8\n' > "$resolv"
        ok "DNS configured"
    fi

    # ── Step 5: Enter and update ─────────────────────────────────────────────
    echo ""
    info "Entering Arch Linux and updating system..."
    echo ""

    exec chroot "$ARCH_PATH" /usr/bin/env -i \
        HOME="/root" \
        PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin" \
        TERM="${TERM:-xterm-256color}" \
        LANG="C.UTF-8" LC_ALL="C.UTF-8" \
        USER="root" SHELL="/bin/bash" \
        /bin/bash -c "pacman-key --init 2>/dev/null; pacman-key --populate archlinuxarm 2>/dev/null; pacman -Syu --noconfirm"
}

cmd_bootstrap() {
    banner "ArchDroid Bootstrap"
    info "Starting secure bootstrap process..."
    ARCHDROID_BOOTSTRAP_ALLOWED=1 ARCHDROID_INTERNAL_CALL=1 exec "${CORE_DIR}/bootstrap.sh" "$@"
}

cmd_start() {
    banner "ArchDroid Runtime"
    info "Starting deterministic runtime system..."
    exec "${CORE_DIR}/runtime.sh" "$@"
}

cmd_update() {
    banner "ArchDroid Update"
    info "Starting atomic update process..."
    exec "${CORE_DIR}/atomic-update.sh" "$@"
}

cmd_doctor() {
    banner "ArchDroid System Diagnostics"
    info "Running comprehensive system inspection..."
    exec "${CORE_DIR}/inspect-runtime.sh" "$@"
}

cmd_verify() {
    banner "ArchDroid Verification"
    info "Running independent system verification..."
    exec "${CORE_DIR}/verify.sh" "$@"
}

cmd_reset_trust() {
    banner "ArchDroid Trust Reset"
    info "Clearing all accumulated trust state..."
    exec "${CORE_DIR}/trust-reset.sh" "$@"
}

cmd_status() {
    banner "ArchDroid System Status"

    if [ -f "$ARCH_PATH/bin/bash" ]; then
        local current_version
        current_version=$(get_current_version "$ARCH_PATH" 2>/dev/null || echo "none")

        if chroot "$ARCH_PATH" /bin/bash -c 'echo ok' >/dev/null 2>&1; then
            ok "Installation: Valid and executable (version: $current_version)"
        else
            warn "Installation: Files present but chroot test failed (version: $current_version)"
            info "Run 'archdroid doctor' — SELinux is a common cause"
        fi
    else
        warn "Installation: Not found"
        info "Run: archdroid up"
        return 1
    fi

    local inspect_status=0
    info "Checking runtime..."
    "${CORE_DIR}/inspect-runtime.sh" >/dev/null 2>&1 || inspect_status=$?
    if [ "$inspect_status" -le 1 ]; then
        ok "Runtime: Ready"
    else
        warn "Runtime: Issues detected — run 'archdroid doctor'"
    fi

    local trust_marker="${ARCH_PATH}/.archdroid-trust-reset"
    if [ -f "$trust_marker" ]; then
        warn "Trust: Reset required"
        info "Run: archdroid reset-trust && archdroid bootstrap"
    else
        ok "Trust: Clean"
    fi

    echo ""
    info "Enter chroot: archdroid start"
}

cmd_help() {
    banner "ArchDroid Commands"
    echo ""
    echo "Quick Start:"
    echo "  up            Bootstrap (if needed) + fix env + enter + pacman -Syu"
    echo ""
    echo "Setup:"
    echo "  bootstrap     Install Arch Linux rootfs"
    echo "  update        Atomically update existing installation"
    echo "  reset-trust   Clear state and force fresh bootstrap"
    echo ""
    echo "Runtime:"
    echo "  start         Enter chroot environment"
    echo "  status        Show installation and runtime status"
    echo ""
    echo "Diagnostics:"
    echo "  doctor        Run comprehensive system inspection"
    echo "  verify        Independent verification"
    echo "  version       Show version and configuration"
    echo ""
    echo "Environment Variables:"
    echo "  ARCH_PATH            Installation path (default: /data/local/arch)"
    echo "  ARCHDROID_FORCE=1    Allow overwriting unmanaged rootfs (requires confirmation)"
    echo "  ARCHDROID_SAFE_MODE=1  Bypass validation gates (debugging only)"
    echo ""
    echo "Examples:"
    echo "  archdroid up                                  # First-time full setup"
    echo "  export ARCH_PATH=/data/local/arch-test        # Test path (safe)"
    echo "  archdroid start                               # Enter chroot"
    echo "  archdroid doctor                              # Diagnose issues"
}

# ─── DISPATCHER ──────────────────────────────────────────────────────────────
main() {
    if [ ! -d "$CORE_DIR" ]; then
        fail "Core directory not found: $CORE_DIR"
        exit 1
    fi

    local command="${1:-help}"
    shift || true

    case "$command" in
        up)              cmd_up "$@" ;;
        bootstrap|install) cmd_bootstrap "$@" ;;
        start|run|enter) cmd_start "$@" ;;
        update|upgrade)  cmd_update "$@" ;;
        doctor|diagnose|check) cmd_doctor "$@" ;;
        verify|validate) cmd_verify "$@" ;;
        reset-trust|reset) cmd_reset_trust "$@" ;;
        status|info)     cmd_status "$@" ;;
        version|--version|-v) cmd_version "$@" ;;
        help|--help|-h)  cmd_help "$@" ;;
        *)
            fail "Unknown command: $command"
            echo ""
            cmd_help
            exit 1
            ;;
    esac
}

if [ "${BASH_SOURCE[0]}" = "${0}" ]; then
    main "$@"
fi
